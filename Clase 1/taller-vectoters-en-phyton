edades = []
print("Ejercicio 4: Ingrese 5 edades")
for i in range(5):
    while True:
        entrada = input(f"Edad {i + 1}: ")
        try:
            edad = int(entrada)
            edades.append(edad)
            break
        except ValueError:
            print("Entrada inválida. Por favor, ingrese un número entero.")

mayores_o_iguales = [edad for edad in edades if edad >= 18]
print("Edades mayores o iguales a 18 años:")
for edad in mayores_o_iguales:
    print(edad)
print()

